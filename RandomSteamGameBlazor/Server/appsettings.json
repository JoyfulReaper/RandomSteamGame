{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "CacheProvider": "Sqlite",
  "DatabaseProvider": "Sqlite",

  "ConnectionStrings": {
    "SqliteCacheConnection": "steam_cache.db",
    "SqliteConnection": "users.db",
    "SqlServerConnection": "Server=YourServer;Database=YourDb;Trusted_Connection=True;",
    "RandomSteamGame": ""
  },

  "SteamOptions": {
    "ApiKey": "",
    "ConnectionString": "SqliteCacheConnection",
    "CacheSchema": "dbo",
    "CacheTable": "Cache"
  },

  "Cache": {
    "OwnedGames": {
      "AbsoluteMinutes": 1440
    },
    "AppDetails": {
      "AbsoluteMinutes": 10080
    },
    "VanitySuccess": {
      "AbsoluteMinutes": 360
    },
    "VanityNotFound": {
      "AbsoluteMinutes": 5
    }
  },

  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "",
    "Audience": "",
    "ExpirationMinutes": 10,
    "RefreshExpirationDays": 7
  },

  "AllowedHosts": "*"
}