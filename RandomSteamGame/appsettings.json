{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Steam": {
    "ApiKey": "YOUR_STEAM_API_KEY_HERE",
    "ConnectionString": "Data Source=steam_cache.db",
    "Cache": {
      "OwnedGames": { "AbsoluteMinutes": 43200 },
      "AppDetails": { "AbsoluteMinutes": 43200 },
      "VanitySuccess": { "AbsoluteMinutes": 21600 },
      "VanityNotFound": { "AbsoluteMinutes": 15 }
    },
    "RateLimiting": {
      "PermitLimit": 20,
      "WindowSeconds": 10
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5281",
      "https://randomsteam.kgivler.com",
      "https://randombeta.kgivler.com",
      "https://kgivler.com",
      "https://www.kgivler.com"
    ]
  },
  "AllowedHosts": "*"
}
