{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CacheProvider": "Sqlite",
  "DatabaseProvider": "Sqlite",

  "ConnectionStrings": {
    "SqliteCacheConnection": "steam_cache.db",
    "SqliteConnection": "users.db",
    "SqlServerConnection": "Server=YourServer;Database=YourDb;Trusted_Connection=True;",
    "RandomSteamGame": ""
  },

  "SteamOptions": {
    "ApiKey": "",
    "ConnectionString": "SqliteCacheConnection",
    "CacheSchema": "dbo",
    "CacheTable": "Cache"
  },

  "Cache": {
    "OwnedGames": {
      "AbsoluteMinutes": 1440
    },
    "AppDetails": {
      "AbsoluteMinutes": 10080
    },
    "VanitySuccess": {
      "AbsoluteMinutes": 1440
    },
    "VanityNotFound": {
      "AbsoluteMinutes": 5
    }
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5281",
      "https://randomsteam.kgivler.com",
      "https://kgivler.com",
      "https://www.kgivler.com"
    ]
  },

  "AllowedHosts": "*"
}