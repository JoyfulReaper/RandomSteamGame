@page "/not-found"
@layout MainLayout

<PageTitle>404: OBJECT NOT FOUND</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="The requested page could not be found." />
</HeadContent>
<LayoutView>
<div class="not-found-wrapper">
    <div class="term-window">
        <div class="term-header">
            <div class="term-dots">
                <span class="term-dot" style="background-color: #ef4444;"></span>
                <span class="term-dot" style="background-color: #f59e0b;"></span>
                <span class="term-dot" style="background-color: #10b981;"></span>
            </div>
            <span class="term-title">bash — error_handler.sh</span>
        </div>

        <div class="term-body">
            <div class="cmd-text">
                <span class="cmd-prompt">kyle@kgivler:~$</span> curl -I https://randomsteam.kgivler.com/requested_route
            </div>

            <h1 class="display-1 fw-bold text-danger mt-3">404</h1>
            <p class="h4 fw-bold text-white mt-2">HTTP_STATUS_NOT_FOUND</p>
            <p class="text-muted px-3 mt-3">The requested vector does not exist or has been detached from the host array. Did you mistype the URI, or did the garbage collector get to it first?</p>

            <div class="err-badge">
                <span class="text-danger fw-bold">[SIGSEGV] SEGMENTATION FAULT</span><br>
                <span class="term-error-dim">Dereferencing null pointer at address 0x0000000000000000</span><br>
                <span class="term-error-light">Reason: The client router returned an empty reference. Capitalist interference suspected. Structural integrity intact but severely offended.</span>
            </div>

            <hr class="term-divider">

            <div>
                <a href="/" class="term-btn">
                    <i class="fas fa-undo me-2"></i>return_to_mainframe.exe
                </a>
            </div>
        </div>
    </div>
</div>
</LayoutView>
