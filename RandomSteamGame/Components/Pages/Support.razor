            true,
            "White-glove custom development, guaranteed delivery, private builds, or separate-license implementations scoped before work begins.",
            "Open GitHub issue")
    ];

    private sealed record SponsorTier(
        string Amount,
        string Name,
        string Description);

    private sealed record RoadmapFeature(
        string Name,
        string Status,
        bool RequiresAccount,
        string Description,
        string Sponsor);
}