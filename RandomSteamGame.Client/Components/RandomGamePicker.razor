@implements IDisposable

@inject PersistentComponentState ApplicationState
@inject ILogger<RandomGamePicker> Logger
@inject RandomSteamApiClient ApiClient
@inject IJSRuntime JSRuntime

@if (_gameDetails is not null)
{
    <PageTitle>Random Steam Game Picker - @_gameDetails.Name</PageTitle>
}

<div class="game-page-wrapper" style="--bg-url: url('@_background')">
    <div class="container-fluid px-3 px-md-5 py-5">
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-warning">@_errorMessage</div>
        }

        @if (_gameDetails is not null && string.IsNullOrEmpty(_errorMessage) && !_isBusy)
        {
            <div class="row">
                <div class="col-12 col-md-5 d-flex flex-column" style="min-height: 300px;">
                    <div id="randomGame">
                        <h4 class="text-info">You should play:</h4>
                        <h1 class="h2">
                            @_gameDetails.Name
                        </h1>
                    </div>

                    <div class="button-footer">
                        <button class="btn btn-primary btn-lg" @onclick="UpdateData">
                            Choose Again
                        </button>

                        <a href="steam://run/@_gameDetails.Id/"
                           class="btn btn-success btn-lg ms-2">
                            Run game
                        </a>
                    </div>
                </div>

                <div class="col-12 col-md-7">
                    <h3 class="mb-3">About the Game</h3>
                    <div id="gameDescription">
                        @((MarkupString)_gameDetails.Description)
                    </div>
                </div>
            </div>
        }
        else if (_isBusy)
        {
            <div class="text-center text-white">
                <h1>Picking a game!</h1>
                <div class="spinner-border" role="status"></div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public long SteamId { get; set; }

    [Parameter]
    public string Provider { get; set; } = "steam";

    private GameDetails? _gameDetails;
    private bool _isBusy;
    private string? _errorMessage;
    private string _background = string.Empty;
    private IJSObjectReference? _themeModule;
    private bool _themeUpdatePending = true;

    private PersistingComponentStateSubscription _subscription;
    private bool _hasRegisteredPersistingCallback;
    private bool _hasRestoredInitialState;
    private long? _lastLoadedSteamId;
    private string? _lastLoadedProvider;

    private string StateKey => $"random-game-details:{Provider}:{SteamId}";

    protected override void OnInitialized()
    {
        if (_hasRegisteredPersistingCallback)
        {
            return;
        }

        _subscription = ApplicationState.RegisterOnPersisting(PersistState);
        _hasRegisteredPersistingCallback = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_hasRestoredInitialState)
        {
            _hasRestoredInitialState = true;

            if (ApplicationState.TryTakeFromJson<GameDetails>(StateKey, out var restored))
            {
                _gameDetails = restored;
                _background = _gameDetails?.HeaderImage ?? string.Empty;
                _themeUpdatePending = true;
                _lastLoadedProvider = Provider;
                _lastLoadedSteamId = SteamId;
                return;
            }
        }

        if (_lastLoadedProvider == Provider &&
            _lastLoadedSteamId == SteamId &&
            _gameDetails is not null)
        {
            return;
        }

        await UpdateData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_themeUpdatePending)
        {
            return;
        }

        try
        {
            _themeModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import",
                "./Components/RandomGamePicker.razor.js");

            await _themeModule.InvokeVoidAsync("updateTheme", ".game-page-wrapper", _background);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Failed to apply adaptive theme for RandomGamePicker.");
        }
        finally
        {
            _themeUpdatePending = false;
        }
    }

    private Task PersistState()
    {
        if (_gameDetails is not null)
        {
            ApplicationState.PersistAsJson(StateKey, _gameDetails);
        }

        return Task.CompletedTask;
    }

    private async Task UpdateData()
    {
        _errorMessage = null;
        _isBusy = true;
        _gameDetails = null;
        _background = string.Empty;
        _themeUpdatePending = true;

        try
        {
            var result = await ApiClient.GetRandomGameDetailsAsync(Provider, steamId: SteamId);

            if (!result.IsSuccess)
            {
                _errorMessage = result.IsTooManyRequests
                    ? "Wow dude, you're like me you like to smash the button. Nicely done you are trying for more than two clicks per second! Please wait a little?"
                    : result.GetErrorMessage("An unexpected error occurred.");

                return;
            }

            _gameDetails = result.Value;

            if (_gameDetails is null)
            {
                _errorMessage = "Unable to retrieve game: API returned empty data.";
                return;
            }

            _background = _gameDetails.HeaderImage ?? string.Empty;
            _themeUpdatePending = true;
            _lastLoadedProvider = Provider;
            _lastLoadedSteamId = SteamId;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error getting random game for {Provider}/{SteamId}", Provider, SteamId);
            _errorMessage = "Unable to pick a game right now. Please try again.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    public void Dispose()
    {
        _subscription.Dispose();
    }
}
