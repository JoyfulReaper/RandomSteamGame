@inject RandomSteamApiClient ApiClient

<p>
    Total Hits: @_totalHits |
    Unique Visitors: @_uniqueVisitors |
    Random Games Generated: @_randomGamesGenerated
</p>

@code {
    private long _totalHits;
    private long _uniqueVisitors;
    private long _randomGamesGenerated;

    protected override async Task OnInitializedAsync()
    {
        if (!RendererInfo.IsInteractive)
        {
            await RecordHitAsync();
        }
        else
        {
            await FetchStatsOnlyAsync();
        }
    }

    private async Task RecordHitAsync()
    {
        var result = await ApiClient.RecordHitAsync();

        if (result.IsSuccess)
        {
            ApplyStats(result.Value);
        }
    }

    private async Task FetchStatsOnlyAsync()
    {
        var result = await ApiClient.GetStatsAsync();

        if (result.IsSuccess)
        {
            ApplyStats(result.Value);
        }
    }

    private void ApplyStats(AppStatsResponse? stats)
    {
        if (stats is null)
        {
            return;
        }

        _totalHits = stats.TotalHits;
        _uniqueVisitors = stats.UniqueVisitors;
        _randomGamesGenerated = stats.RandomGamesGenerated;
    }
}