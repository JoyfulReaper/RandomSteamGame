@page "/random-game/{Provider}/{SteamId:long}"
@implements IDisposable
@inject PersistentComponentState ApplicationState
@inject ILogger<RandomGame> _logger
@inject RandomSteamApiClient ApiClient

<HeadContent>
    <meta name="keywords" content="Random Steam Game, Steam Game Picker, Random Game, Random Steam Game Picker, Game Picker, Random Game Picker, Steam, Valve" />
    <meta name="description" content="Discover your next game with our Random Steam Game Picker. Fast, easy, and built for your library." />
    <meta name="author" content="Kyle Givler" />
</HeadContent>

@if (_gameDetails is not null)
{
    <PageTitle>Random Steam Game Picker - @_gameDetails.Name</PageTitle>
}
else
{
    <PageTitle>Random Steam Game Picker - Find Your Next Game</PageTitle>
}

<div class="game-page-wrapper" style="--bg-url: url('@_background')">
    <div class="container-fluid px-3 px-md-5 py-5">
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-warning">@_errorMessage</div>
            <button class="btn btn-primary btn-lg" @onclick="UpdateData">Try Again</button>
        }

        @if (_gameDetails is not null && string.IsNullOrEmpty(_errorMessage) && !_isBusy)
        {
            <div class="row">
                <div class="col-12 col-md-5 d-flex flex-column" style="min-height: 300px;">

                    <div id="randomGame" class="flex-grow-1">
                        <h4 class="text-info">You should play:</h4>
                        <h1 class="h2" style="font-size: 1.8rem; line-height: 1.2;">@_gameDetails.Name</h1>
                    </div>

                    <div class="button-footer">
                        <button class="btn btn-primary btn-lg" @onclick="UpdateData">Choose Again</button>
                        <a href="steam://run/@_gameDetails.Id/" class="btn btn-success btn-lg ms-2">Run game</a>
                    </div>
                </div>

                <div class="col-12 col-md-7">
                    <h3 class="mb-3">About the Game</h3>
                    <div id="gameDescription">
                        @((MarkupString)_gameDetails.Description)
                    </div>
                </div>
            </div>
        }
        else if (_isBusy)
        {
            <div class="text-center text-white">
                <h1>Picking a game!</h1>
                <div class="spinner-border" role="status"></div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public long? SteamId { get; set; }

    [Parameter]
    public string Provider { get; set; } = "steam";

    private GameDetails? _gameDetails;
    private bool _isBusy = false;
    private string? _errorMessage;
    private string _background = string.Empty;
    private PersistingComponentStateSubscription _subscription;

    protected override async Task OnInitializedAsync()
    {
        //Try to restore from prerendered state
        if (!ApplicationState.TryTakeFromJson<GameDetails>("game-details", out var restored))
        {
            await UpdateData();
        }
        else
        {
            _gameDetails = restored;
            _background = _gameDetails?.HeaderImage ?? string.Empty;
        }

        // Register for persistence
        _subscription = ApplicationState.RegisterOnPersisting(PersistState);
    }

    private Task PersistState()
    {
        if (_gameDetails != null)
            ApplicationState.PersistAsJson("game-details", _gameDetails);
        return Task.CompletedTask;
    }

    private async Task UpdateData()
    {
        _errorMessage = null;
        _isBusy = true;

        try
        {
            var result = await ApiClient.GetRandomGameDetailsAsync(Provider, steamId: SteamId);

            if (!result.IsSuccess)
            {
                if (result.IsTooManyRequests)
                {
                    _errorMessage = "Wow dude, you're like me you like to smash the button. Nicely done you are trying for more than two clicks per second! Please wait a little?";
                }
                else
                {
                    _errorMessage = result.GetErrorMessage("An unexpected error occurred.");
                }

                return;
            }

            _gameDetails = result.Value;
            if (_gameDetails is null)
            {
                _errorMessage = "Unable to retrieve game: API returned empty data.";
                return;
            }

            _background = _gameDetails.HeaderImage ?? string.Empty;
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error getting random game for {SteamId}", SteamId);
            _errorMessage = "Unable to pick a game right now. Please try again.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    public void Dispose() =>
        _subscription.Dispose();
}
