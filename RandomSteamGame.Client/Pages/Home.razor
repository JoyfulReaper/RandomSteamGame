@page "/"
@implements IDisposable
@inject PersistentComponentState ApplicationState
@inject ILocalStorageService _localStorageService
@inject NavigationManager _navigationManager
@inject ISteamIdentityService _steamIdentityService
@inject IHttpClientFactory _clientFactory

<HeadContent>
    <meta name="keywords" content="Random Steam Game, Steam Game Picker, Random Game, Random Steam Game Picker, Game Picker, Random Game Picker, Steam, Valve" />
    <meta name="description" content="Discover your next game with our Random Steam Game Picker. Fast, easy, and built for your library." />
    <meta name="author" content="Kyle Givler" />
</HeadContent>

<PageTitle>Random Steam Game Picker - Find Your Next Game</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger mb-4" role="alert">@_errorMessage</div>
            }

            @if (_isDataLoading)
            {
                <div id="app">
                    <div class="loader-container">
                        <div class="terminal-loader-box">
                            <div class="spinner-line text-start">
                                <span style="color: #38bdf8;">kyle@kgivler:~$</span> dotnet run WASM_Client...
                            </div>
                            <div class="text-start mt-3" style="color: #e2e8f0; font-size: 0.95rem;">
                                <i class="fas fa-circle-notch fa-spin me-2" style="color: #38bdf8;"></i> Initializing framework runtime <span class="blinking-cursor"></span>
                            </div>
                            <div class="loader-subtext text-start border-top border-secondary mt-3 pt-2">
                                Allocating local buffers & parsing assemblies...
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="main-card">
                    <h2 class="text-center mb-4 text-white">Random Steam Picker</h2>

                    <EditForm Model="_homePageModel" OnValidSubmit="HandleValidSubmit">
                        <div class="mb-3">
                            <label class="form-label">17 Digit Steam ID</label>
                            <InputNumber class="form-control modern-input" @bind-Value="_homePageModel.SteamId" />
                        </div>

                        <div class="text-center fw-bold my-2 text-muted">OR</div>

                        <div class="mb-4">
                            <label class="form-label">Steam Vanity/Custom URL</label>
                            <InputText class="form-control modern-input" @bind-Value="_homePageModel.VanityUrl" />
                        </div>

                        <button type="submit" class="btn btn-steam w-100 py-2" disabled="@_isBusy">
                            @if (_isBusy)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Generate Random Game
                    </button>
                </EditForm>
            </div>
            }

            <div class="text-center mt-4 text-muted small">
                <p>
                    Need help finding your Steam ID? Check the <a href="https://help.steampowered.com/en/faqs/view/2816-BE67-5B69-0FEC" target="_blank" class="text-info">Steam ID guide</a>.
                    Ensure your <a href="https://help.steampowered.com/en/faqs/view/588C-C67D-0251-C276" target="_blank" class="text-info">profile is public</a>.
                </p>
                @if (!_isDataLoading)
                {
                    <p>
                        Total Hits:<a href="#"></a> @_totalHits | Unique Visitors:<a href="#"></a> @_uniqueVisitors
                    </p>
                }
            </div>

        </div>
    </div>
</div>

@code {
    private HomeModel _homePageModel = new HomeModel();

    private PersistingComponentStateSubscription _subscription;

    private string? _errorMessage;
    private bool _isBusy = false;
    private bool _isDataLoading = true;

    private long _totalHits;
    private long _uniqueVisitors;

    private class HitStatsResponse
    {
        public long TotalHits { get; set; }
        public long UniqueVisitors { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        if (ApplicationState.TryTakeFromJson<HomeModel>("home-model", out var restored))
        {
            _homePageModel = restored!;
        }

        _subscription = ApplicationState.RegisterOnPersisting(PersistState);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var browserSteamId = await _steamIdentityService.GetSteamIdAsync();
            var browserVanity = await _steamIdentityService.GetVanityUrlAsync();

            if (browserSteamId.HasValue || !string.IsNullOrEmpty(browserVanity))
            {
                _homePageModel.SteamId = browserSteamId;
                _homePageModel.VanityUrl = browserVanity;
            }

            await RecordHitAsync();

            _isDataLoading = false;
            StateHasChanged();
        }
    }

    private Task PersistState()
    {
        ApplicationState.PersistAsJson("home-model", _homePageModel);
        return Task.CompletedTask;
    }

    private async Task HandleValidSubmit()
    {
        _errorMessage = null;
        _isBusy = true;
        StateHasChanged();

        try
        {
            if (_homePageModel.SteamId is null && !string.IsNullOrWhiteSpace(_homePageModel.VanityUrl))
            {
                var _client = _clientFactory.CreateClient("ApiClient");
                var response = await _client.GetAsync($"api/steam/resolve/{Uri.EscapeDataString(_homePageModel.VanityUrl)}");

                if (response.IsSuccessStatusCode)
                {
                    _homePageModel.SteamId = await response.Content.ReadFromJsonAsync<long>();
                }
                else
                {
                    throw new Exception("Unable to resolve vanity URL. Check the URL and try again.");
                }
            }

            if (_homePageModel.SteamId.HasValue)
            {
                await _steamIdentityService.SetIdentityAsync(_homePageModel.SteamId.Value, _homePageModel.VanityUrl);
                _navigationManager.NavigateTo($"/random-game/steam/{_homePageModel.SteamId.Value}");
            }
            else
            {
                _errorMessage = "Please enter a valid Steam ID or Vanity URL.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
            StateHasChanged();
        }
    }

    private async Task RecordHitAsync()
    {
        try
        {
            var client = _clientFactory.CreateClient("ApiClient");
            var response = await client.PostAsync("api/stats/hit", null);

            if (response.IsSuccessStatusCode)
            {
                var stats = await response.Content.ReadFromJsonAsync<HitStatsResponse>();
                if (stats != null)
                {
                    _totalHits = stats.TotalHits;
                    _uniqueVisitors = stats.UniqueVisitors;
                }
            }
        }
        catch { /* Fail silently */ }
    }

    public void Dispose() => 
        _subscription.Dispose();

}